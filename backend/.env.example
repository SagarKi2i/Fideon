SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEVICE_JWT_SECRET=
PERSONAL_API_KEY_PEPPER=
CORS_ALLOWED_ORIGINS=

# --- FastAPI on RunPod, Next.js on your machine ---
# The app merges localhost/127.0.0.1:3000 and :3003 into CORS automatically (see factory.py).
# Set CORS_ALLOWED_ORIGINS if you use a non-localhost dev URL (tunnel, LAN IP, custom port).
# Behind RunPod HTTPS proxy, TRUST_PROXY_HEADERS=true helps rate limits / client IP when safe.
# Your RunPod pod still needs the same Supabase and DEVICE_JWT_SECRET as local dev unless you use separate projects.

# Rate limiter proxy behavior:
# - true: trust X-Forwarded-For / X-Real-IP (only when behind trusted ingress)
# - false: use direct client IP from socket
TRUST_PROXY_HEADERS=false

# Legacy token-based device endpoints (/api/device-*) are kept for backward compatibility.
# Disable in production once all clients use /api/v1/devices/* JWT flow.
LEGACY_DEVICE_TOKEN_APIS_ENABLED=false

# Primary provider: Groq
GROQ_API_KEY=
GROQ_OPENAI_COMPAT_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL_CHAT=llama-3.3-70b-versatile
GROQ_MODEL_HELP=llama-3.3-70b-versatile
GROQ_MODEL_WORKFLOW=llama-3.3-70b-versatile

# Fallback provider 1/2: RunPod
# Preferred mode: direct /generate endpoint with FIDEON_SECRET_KEY bearer
FIDEON_SECRET_KEY=
RUNPOD_GENERATE_URL=https://8e7k92f9vcuxzh-8000.proxy.runpod.net/generate
RUNPOD_API_KEY=
RUNPOD_OPENAI_COMPAT_URL=
RUNPOD_MODEL_LLAMA=meta-llama/Meta-Llama-3.1-8B-Instruct
RUNPOD_MODEL_MISTRAL=mistralai/Mistral-7B-Instruct-v0.3
OFFLINE_LLM_FALLBACK_ENABLED=false

# RunPod GraphQL pod control + ML HTTP proxy (factory: runpod_control, ml_acord_proxy)
# RUNPOD_API_KEY is Bearer for https://api.runpod.io/graphql
#
# Single pod (browser NEXT_PUBLIC_API_URL = this origin): set all three to the same pod.
# Example: uvicorn --port 8000 → RUNPOD_POD_ID=<id>, RUNPOD_PROXY_BASE_URL=https://<id>-8000.proxy.runpod.net,
#   RUNPOD_GENERATE_URL=https://<id>-8000.proxy.runpod.net/generate
RUNPOD_POD_ID=
POD_ID=
# HTTPS origin of the pod port where THIS FastAPI app listens (same host as uvicorn). Must match exposed port, e.g.
# https://YOUR_POD_ID-8000.proxy.runpod.net — no trailing slash. If empty, derived from RUNPOD_GENERATE_URL (strip /generate).
RUNPOD_PROXY_BASE_URL=
PROXY_URL=
# ML route the BFF proxies to after RunPod is ready (same app: acord router POST /extract under prefix /api/acord).
RUNPOD_ML_ACORD_EXTRACT_PATH=/api/acord/extract
RUNPOD_ML_READY_TIMEOUT_SEC=600
# ML readiness GET path(s), comma-separated, tried in order. Must return 2xx on the SAME host as RUNPOD_PROXY_BASE_URL.
RUNPOD_ML_HEALTH_PATH=/health,/readyz,/docs,/openapi.json
# Poll GraphQL until pod desiredStatus=RUNNING (seconds).
RUNPOD_POD_RUNNING_TIMEOUT_SEC=300
RUNPOD_POD_RUNNING_POLL_INITIAL_SEC=3
RUNPOD_POD_RUNNING_POLL_MAX_SEC=20
RUNPOD_ML_HEALTH_POLL_INITIAL_SEC=2
RUNPOD_ML_HEALTH_BACKOFF_MAX_SEC=30
# false = HTTP-only: GraphQL resume + RUNNING poll + GET RUNPOD_ML_HEALTH_PATH (recommended).
RUNPOD_SSH_ENABLED=false
# Optional SSH after pod resume (aliases: SSH_HOST, SSH_USER, …)
RUNPOD_SSH_HOST=
RUNPOD_SSH_USER=root
RUNPOD_SSH_PORT=22
RUNPOD_SSH_KEY_PATH=
RUNPOD_SSH_PRIVATE_KEY=
RUNPOD_REMOTE_START_SCRIPT=/workspace/start_backend.sh
RUNPOD_SSH_MAX_RETRIES=20
RUNPOD_SSH_RETRY_DELAY_SEC=5
# Seconds after GraphQL RUNNING before first ML HTTP check (proxy/GPU); SSH timing below.
RUNPOD_POST_RESUME_GRACE_SEC=45
RUNPOD_PRE_SSH_DELAY_SEC=60

# ACORD offline/chat endpoints (acord routes — read directly via os.getenv in places)
# If OFFLINE_LLM_GENERATE_URL is http://127.0.0.1:PORT/generate on the same process as uvicorn, set ENABLE_LOCAL_GENERATE=true.
ENABLE_LOCAL_GENERATE=false
ENABLE_LOCAL_GENERATE_WARMUP=false
OFFLINE_LLM_GENERATE_URL=
OPENAI_CHAT_COMPLETIONS_URL=
ACORD_USE_OFFLINE_LLM=true
# Set to true to generate a natural language narrative after each extraction (uses OFFLINE_LLM_GENERATE_URL or chat endpoint).
ACORD_NL_SUMMARY_ENABLED=false

# LLMFallbackService cache / extra providers
LLM_CACHE_BACKEND=local
LLM_SEMANTIC_CACHE_ENABLED=false
HUGGINGFACE_API_KEY=
MOMENTO_API_KEY=

# Fallback provider 3: Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Fallback provider 4: OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Fallback provider 5: Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MESSAGES_URL=https://api.anthropic.com/v1/messages
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# --- ACORD: extraction (main API) vs Playground BFF ---
# Main app: POST /api/acord/extract (same FastAPI; uses Models/ + LLM keys — no RunPod required).
# Playground: POST /api/v1/ml/acord/extract on THIS backend → ensure_runpod_ml_ready() → proxies multipart to
#   RUNPOD_PROXY_BASE_URL + RUNPOD_ML_ACORD_EXTRACT_PATH (the ML pod must run the same app with uvicorn bound to 0.0.0.0).
# Keys: RUNPOD_API_KEY + RUNPOD_POD_ID (GraphQL), RUNPOD_PROXY_BASE_URL (or RUNPOD_GENERATE_URL for base-URL derivation).

# --- ACORD / Pod: approval → automatic fine-tuning (fine_tuning/job_runner.py) ---
# Install deps: pip install -r requirements.txt on the GPU machine that runs training (Linux + NVIDIA typical).
# Hugging Face gated models — set one of:
# HF_TOKEN=
# Optional: FINE_TUNE_LOCAL_FILES_ONLY=true only if base_model points to a local directory (see fine_tuning/config.yaml).
AUTO_FINE_TUNE_ON_ACORD_APPROVAL=true
AUTO_FINE_TUNE_ON_POD_APPROVAL=true
FINE_TUNING_CONFIG_PATH=fine_tuning/config.yaml
ACORD_TRAINING_APPROVED_LIMIT=500
# Minimum JSONL rows after export before training runs (job_runner default if unset: 80). Lower only for dev tests.
ACORD_TRAINING_MIN_RECORDS=80
# Pod-mode training (pod_training_jobs): minimum rows (default in code if unset: 200).
POD_TRAINING_MIN_RECORDS=200
# RAG / ingestion (optional for some ACORD flows)
PGVECTOR_DATABASE_URL=
PGVECTOR_TABLE=rag_chunks

# --- SeaweedFS S3-compatible object store ---
# Upload destination for fine-tuned adapter weights and quantized GGUF artifacts.
# Filer exposes an S3-compatible API on port 8333 by default.
SEAWEEDFS_ENDPOINT=http://<host>:8333
SEAWEEDFS_ACCESS_KEY=
SEAWEEDFS_SECRET_KEY=
SEAWEEDFS_BUCKET=my-bucket

# --- Post-training quantization pipeline (fine_tuning/quantize_pipeline.py) ---
# GGUF quant levels produced after each successful fine-tune job.
# Needs llama.cpp tools on PATH (convert_hf_to_gguf.py + llama-quantize).
# If tools are absent the merged HF weights are uploaded to SeaweedFS instead.
FT_QUANT_LEVELS=q4_k_m,q5_k_m
FT_REGISTRY_CANARY_PCT=100
FT_QUANT_SKIP=0
LLAMA_CPP_CONVERT_SCRIPT=
LLAMA_CPP_QUANTIZE_BIN=

# --- SQLite training dataset store ---
# Local .db file that records every training example used per fine-tune job.
# Leave empty for default: fine_tuning/training_datasets.db
FT_DATASET_DB_PATH=

# NOTE:
# - Frontend auth/SSO/MFA flags are configured in frontend/.env.local
# - Apply Supabase migrations from repository root before backend startup
# - DEVICE_JWT_SECRET is required for /api/v1/devices/register + /api/v1/devices/heartbeat
# - Fallback order used by backend: Groq -> RunPod Llama -> RunPod Mistral -> Gemini -> OpenAI -> Claude
# - ACORD Playground + fine-tuning need Supabase service role + tables (e.g. acord_training_jobs); check job logs under fine_tuning/runs/job_<id>.log
# - After fine-tuning, adapter weights land at adapters/{domain}/{version}/ in SeaweedFS,
#   quantized GGUFs land at gguf/{domain}/{version}/, and are registered in adapter_registry.
