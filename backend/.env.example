SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEVICE_JWT_SECRET=
PERSONAL_API_KEY_PEPPER=
CORS_ALLOWED_ORIGINS=

# Rate limiter proxy behavior:
# - true: trust X-Forwarded-For / X-Real-IP (only when behind trusted ingress)
# - false: use direct client IP from socket
TRUST_PROXY_HEADERS=false

# Legacy token-based device endpoints (/api/device-*) are kept for backward compatibility.
# Disable in production once all clients use /api/v1/devices/* JWT flow.
LEGACY_DEVICE_TOKEN_APIS_ENABLED=false

# Primary provider: Groq
GROQ_API_KEY=
GROQ_OPENAI_COMPAT_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL_CHAT=llama-3.3-70b-versatile
GROQ_MODEL_HELP=llama-3.3-70b-versatile
GROQ_MODEL_WORKFLOW=llama-3.3-70b-versatile

# Fallback provider 1/2: RunPod
# Preferred mode: direct /generate endpoint with FIDEON_SECRET_KEY bearer
FIDEON_SECRET_KEY=
RUNPOD_GENERATE_URL=https://8e7k92f9vcuxzh-8000.proxy.runpod.net/generate
RUNPOD_API_KEY=
RUNPOD_OPENAI_COMPAT_URL=
RUNPOD_MODEL_LLAMA=meta-llama/Meta-Llama-3.1-8B-Instruct
RUNPOD_MODEL_MISTRAL=mistralai/Mistral-7B-Instruct-v0.3

# Fallback provider 3: Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Fallback provider 4: OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Fallback provider 5: Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MESSAGES_URL=https://api.anthropic.com/v1/messages
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# NOTE:
# - Frontend auth/SSO/MFA flags are configured in frontend/.env.local
# - Apply Supabase migrations from repository root before backend startup
# - DEVICE_JWT_SECRET is required for /api/v1/devices/register + /api/v1/devices/heartbeat
# - Fallback order used by backend: Groq -> RunPod Llama -> RunPod Mistral -> Gemini -> OpenAI -> Claude
# - This comment also exists to help bootstrap initial SonarQube analysis without changing any runtime behavior.
