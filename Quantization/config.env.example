# SeaweedFS S3 Gateway (use private IP — no public exposure)
SEAWEEDFS_ENDPOINT=https://<seaweedfs-filer-ip>:8333
SEAWEEDFS_ACCESS_KEY=<your-access-key>
SEAWEEDFS_SECRET_KEY=<your-secret-key>
SEAWEEDFS_BUCKET=models

# Supabase adapter_registry
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Model paths
HF_TOKEN=<huggingface-read-token>
BASE_MODEL_ID=Qwen/Qwen2.5-14B-Instruct   # HF repo ID for auto-download
BASE_MODEL_PATH=/workspace/base_model
ADAPTER_PATH=/workspace/adapter
OUTPUT_DIR=/workspace/gguf_output

# Artifact metadata (written to manifest.json + Supabase)
MODEL_VERSION=v1.2.0         # semver — bump on every run
DOMAIN=broker                # adapter domain: broker | mga | carrier
MIN_ELECTRON_VER=28.0.0      # minimum Electron version for edge delivery
CANARY_PCT=5                 # initial rollout percentage (5 → 25 → 50 → 100)
ROLLBACK_SAFE=true           # set false for breaking schema changes
