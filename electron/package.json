{
  "name": "fideon-electron",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "dev": "npm run build && npm start",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "next-electron-rsc": "^0.3.0"
  },
  "build": {
    "appId": "com.fideon.os",
    "productName": "Fideon OS",
    "forceCodeSigning": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "package.json",
        "to": "package.json"
      },
      {
        "from": "../frontend/.next/standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend/.next/static",
        "to": ".next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend/public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend/.next",
        "to": ".next",
        "filter": [
          "required-server-files.json",
          "server/functions-config-manifest.json"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon-256.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon-256.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon-256.png"
    }
  }
}
